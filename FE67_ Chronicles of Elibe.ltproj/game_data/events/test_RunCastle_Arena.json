[
    {
        "name": "RunCastle_Arena",
        "trigger": null,
        "level_nid": "test",
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "#This shit has already taken hours of my life to try fixing and it's still not done. Do not run this yet!!",
            "",
            "t;close",
            "t;open",
            "#Get the tier of the player's class",
            "level_var;EntrantTier;(game.get_klass(unit.nid)).tier",
            "",
            "#Get the weapon type of the player's weapon",
            "level_var;EntrantWType;item_system.weapon_type(unit, unit.get_weapon())",
            "",
            "#Create some dicts for later",
            "level_var;ArenaRangeDict;{'Sword':0,'Lance':0,'Axe':0,'Bow':1,'Staff':2,'Light':2,'Anima':2,'Dark':2}",
            "level_var;ArenaItemDict;{'Sword': 'Iron Sword', 'Lance': 'Iron Lance', 'Axe': 'Iron Axe', 'Bow': 'Iron Bow', 'Staff': 'Heal', 'Light': 'Lightning', 'Anima': 'Fire', 'Dark': 'Flux'}",
            "",
            "#Find all enemy classes that have a tier equal to the entrant's, ignoring 'ArenaIgnore' classes",
            "level_var;ArenaEnemyKlassList;[k.nid for k in DB.classes if 'ArenaIgnore' not in k.tags and k.tier == game.level_vars['EntrantTier']]",
            "",
            "speak;;{v:ArenaEnemyKlassList}",
            "",
            "for;KlassToCheck;[k for k in DB.classes]",
            "    speak;;{KlassToCheck}",
            "    speak;;{DB.classes}",
            "endf",
            "",
            "",
            "",
            "#Pick a random class from the valid class list",
            "level_var;KlassRNG;game.get_random(0, len(game.level_vars['ArenaEnemyKlassList']) - 1)",
            "level_var;ArenaEnemyKlass;game.level_vars['ArenaEnemyKlassList'][game.level_vars['KlassRNG']]",
            "",
            "#Randomize the enemy's level. By default it randomizes to the unit's level plus or minus 4. The enemy's level cannot break the minimum of 1 or the class maximum.",
            "level_var;low_level;max(1, unit.level - 4)",
            "level_var;high_level;min(DB.classes.get(game.level_vars['ArenaEnemyKlass']).max_level, unit.level + 4)",
            "level_var;ArenaEnemyLevel;game.get_random(game.level_vars['low_level'], game.level_vars['high_level'])"
        ],
        "nid": "test RunCastle_Arena"
    }
]