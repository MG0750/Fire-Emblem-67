        "_source": [
            "if;{v:_refresh} == False",
            "    t;close;0;no_block",
            "end",
            "",
            "#We finally arrive at the main castle event.",
            "change_background;Village",
            "music;Combat Preparation",
            "#Tables make for easier center-aligned text than textboxes",
            "table;Location;{v:_currentCastle};;;240;top;;;center",
            "",
            "#Merlinus shopkeep portrait based on Cygnus' empty blacksmith portrait.",
            "#draw_overlay_sprite;ArenaPortrait;arena_portrait;4,4;1",
            "#add_portrait;Merlinus_Vendor;(-15,12);immediate;mirror",
            "",
            "if;{v:_refresh} == False",
            "    t;open;no_block",
            "end",
            "",
            "#Draw the player's chosen unit",
            "add_portrait;{v:_chosenUnit};MidRight,Middle;right;immediate;no_block",
            "#Ask the player what they want to do with this unit",
