            "\u2028#Clear stuff for the transition",
            "remove_table;Location",
            "remove_portrait;{v:_chosenUnit};immediate",
            "",
            "#Handle the player's choice",
            "if;'{v:_castleChoice}' == 'Repair'",
            "    speak;Merlinus_Vendor;no repairs yet.",
            "elif;'{v:_castleChoice}' == 'Pawn Shop'",
            "    speak;Merlinus_Vendor;no pawning yet.",
            "elif;'{v:_castleChoice}' == 'Inventory'",
            "    speak;Merlinus_Vendor;no management yet.",
            "    ",
            "    open_convoy;{v:_chosenUnit}",
            "    ",
            "elif;'{v:_castleChoice}' == 'Arena'",
            "",
            "    speak;{v:_chosenUnit};\"This isn't finished yet.\"",
            "    level_var;_refresh;True",
            "    trigger_script;test RunCastle_Market;{v:_chosenUnit}",
            "    #trigger_script;test vanilla_lt_arena;{unit}",
            "    ",
            "elif;'{v:_castleChoice}' == 'Augury'",
            "    speak;;no fortune telling yet.",
            "elif;'{v:_castleChoice}' == 'Armory'",
            "    trigger_script;test RunCastle_Armory;{v:_chosenUnit}",
            "else",
            "    sound;Select 4",
            "    trigger_script;Global RunCastle_units",
            "end"
        ],
        "nid": "test RunCastle_Market"
    }
